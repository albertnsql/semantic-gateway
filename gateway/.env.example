# ============================================================
# AI Semantic Gateway — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to source control.
# ============================================================

# --- Google Gemini ---
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-3.1-flash-lite
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.0

# --- OpenRouter ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Snowflake ---
SNOWFLAKE_ACCOUNT=your-account.snowflakecomputing.com
SNOWFLAKE_USER=your_snowflake_user
SNOWFLAKE_PASSWORD=your_snowflake_password
SNOWFLAKE_DATABASE=streaming_analytics
SNOWFLAKE_WAREHOUSE=compute_wh
SNOWFLAKE_ROLE=transformer
SNOWFLAKE_SCHEMA=marts

# --- dbt / MetricFlow Paths ---
MANIFEST_PATH=../dbt_streaming_analytics/streaming_analytics/target/manifest.json
METRICS_PATH=../dbt_streaming_analytics/streaming_analytics/metrics
SEMANTIC_MODELS_PATH=../dbt_streaming_analytics/streaming_analytics/models/semantic

# --- Gateway Runtime ---
GATEWAY_ENV=development
LOG_LEVEL=INFO

# --- Security ---
# API key for cost-bearing routes (/query, /dashboard). Required in production.
GATEWAY_API_KEY=
# Comma-separated allowed CORS origins. Restrict in production.
CORS_ALLOWED_ORIGINS=*
